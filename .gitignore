# 密钥与本地缓存，永远不提交
.env
*.local

# oh-my-pi 运行时产物（全部排除——每次跑 omp 都会变化）
sessions/
terminal-sessions/
logs/
cache/
plugins/
node_modules/

# oh-my-pi sqlite 数据库（会话历史、模型缓存等）
*.db
*.db-shm
*.db-wal

# Incerto 权威源（19MB 二进制；在 .omc/incerto/ 处理后不需要进 git）
incerto-5-book-bundle.epub
incerto-5-book-bundle.epub:Zone.Identifier

# Incerto 运行时产物（脚本进 git，构建出来的索引/分块/日志不进——可以本地从 epub 重建）
.omc/incerto/chunks/
.omc/incerto/index.json
.omc/incerto/query-log.jsonl
.omc/incerto/bun.lock
.omc/incerto/bun.lockb

# MAGI 运行时调试产物（本地审查用，不提交）
.omc/qa/runs/

# 编译产物
dist/
*.js.map
*.d.ts.map

# 编辑器
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# taleb-pi 环境变量模板
# 复制为 .env 后填入实际密钥

# ─── 主模型 (Anthropic) ───────────────────────
ANTHROPIC_API_KEY=

# ─── 备选 provider ────────────────────────────
# OPENAI_API_KEY=
# OPENROUTER_API_KEY=
# DEEPSEEK_API_KEY=

# ─── oh-my-pi 内核行为 ────────────────────────
# 把 ~/.omp/agent 指向本仓库（如果不用软链）
# PI_CODING_AGENT_DIR=C:\Users\ming\taleb-pi

# 关闭 PTY bash（Windows 上有时不稳定）
# PI_NO_PTY=1
